# ==============================================================
# NDIDD — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================

# --------------------------------------------------------------
# Application
# --------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
PORT=3001

# --------------------------------------------------------------
# Database
# --------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/ndidd_dev
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/ndidd_test
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --------------------------------------------------------------
# Redis
# --------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --------------------------------------------------------------
# JWT / Auth
# --------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret-minimum-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-secret
REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=change-me-to-yet-another-long-random-secret

# --------------------------------------------------------------
# Ethereum RPC Endpoints
# --------------------------------------------------------------
# Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_RPC_URL_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_RPC_URL_FALLBACK=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL_WS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arbitrum One
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_RPC_URL_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# BNB Smart Chain
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Testnets
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Local
LOCALHOST_RPC_URL=http://127.0.0.1:8545

# --------------------------------------------------------------
# Provider API Keys
# --------------------------------------------------------------
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
INFURA_PROJECT_SECRET=YOUR_INFURA_PROJECT_SECRET
QUICKNODE_API_KEY=YOUR_QUICKNODE_KEY

# --------------------------------------------------------------
# Block Explorer API Keys (contract verification)
# --------------------------------------------------------------
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY
OPTIMISTIC_ETHERSCAN_API_KEY=YOUR_OPTIMISTIC_ETHERSCAN_API_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY
BSCSCAN_API_KEY=YOUR_BSCSCAN_API_KEY
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_API_KEY

# --------------------------------------------------------------
# WalletConnect
# --------------------------------------------------------------
WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# --------------------------------------------------------------
# Deployment Wallets (use hardware wallet in production)
# --------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
DEPLOYER_MNEMONIC=test test test test test test test test test test test junk

# --------------------------------------------------------------
# Contract Addresses (updated after each deployment)
# --------------------------------------------------------------
# Mainnet
MAINNET_CHAIN_ID=1
MAINNET_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
MAINNET_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
MAINNET_GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000
MAINNET_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
MAINNET_MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon
POLYGON_CHAIN_ID=137
POLYGON_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
POLYGON_BRIDGE_ADDRESS=0x0000000000000000000000000000000000000000

# Arbitrum
ARBITRUM_CHAIN_ID=42161
ARBITRUM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Sepolia testnet
SEPOLIA_CHAIN_ID=11155111
SEPOLIA_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
SEPOLIA_STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# Local (Hardhat / Anvil node)
LOCAL_CHAIN_ID=31337
LOCAL_TOKEN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
LOCAL_STAKING_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# --------------------------------------------------------------
# The Graph
# --------------------------------------------------------------
SUBGRAPH_DEPLOY_KEY=YOUR_THE_GRAPH_DEPLOY_KEY
GRAPH_NODE_URL=http://localhost:8020
IPFS_URL=http://localhost:5001
SUBGRAPH_NAME=ndidd/ndidd
NEXT_PUBLIC_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/ndidd/ndidd
NEXT_PUBLIC_SUBGRAPH_URL_POLYGON=https://api.thegraph.com/subgraphs/name/ndidd/ndidd-polygon

# --------------------------------------------------------------
# Frontend (NEXT_PUBLIC_ vars are exposed to the browser)
# --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
NEXT_PUBLIC_ALCHEMY_KEY=YOUR_PUBLIC_ALCHEMY_KEY
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# --------------------------------------------------------------
# Backend / API
# --------------------------------------------------------------
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --------------------------------------------------------------
# Email / SMTP
# --------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASSWORD
EMAIL_FROM=noreply@ndidd.io
EMAIL_FROM_NAME=NDIDD

# Alternatively use a transactional provider:
SENDGRID_API_KEY=
RESEND_API_KEY=

# --------------------------------------------------------------
# Storage (IPFS / S3)
# --------------------------------------------------------------
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_API_KEY=YOUR_PINATA_SECRET_KEY
PINATA_JWT=YOUR_PINATA_JWT
NFT_STORAGE_API_KEY=YOUR_NFT_STORAGE_KEY
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=ndidd-assets

# --------------------------------------------------------------
# Monitoring & Observability
# --------------------------------------------------------------
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# --------------------------------------------------------------
# CI / CD
# --------------------------------------------------------------
CI=false
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
